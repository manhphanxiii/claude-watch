{
  "name": "claude-watch",
  "version": "0.1.1",
  "description": "Reliability supervisor for unattended (cron/CI/Routines) Claude Code and Agent SDK runs: stall/hang timeout, silent-failure detectors, webhook/Slack alerts.",
  "type": "commonjs",
  "bin": {
    "claude-watch": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "start": "node dist/cli.js",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "cli",
    "reliability",
    "watchdog",
    "headless",
    "cron",
    "ci",
    "agent-sdk"
  ],
  "dependencies": {
    "cross-spawn": "^7.0.3"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/node": "^20.14.10",
    "@types/cross-spawn": "^6.0.6"
  }
}
